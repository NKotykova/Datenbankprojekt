# Vorlage fuer Umgebungsvariablen
# Datei kopieren, umbenennen in .env und echte Werte eintragen.
# Die .env-Datei wird NICHT ins Repository hochgeladen (.gitignore).

# Verbindung als Superuser (fuer den Datenimport)
DB_USER=postgres
DB_PASSWORD=dein_passwort
DB_HOST=localhost
DB_PORT=5433
DB_NAME=mein_praxisprojekt

# Verbindung als Datenanalyst (nur Lesezugriff)
DB_USER_ANALYST=schmidt
DB_PASSWORD_ANALYST=dein_passwort_analyst
